# CommonWell Automation - Environment Variables
# Copy this file to .env and fill in your actual credentials
#   copy .env.example .env

# Your CommonWell login email
CW_USERNAME=your-email@example.com

# Your CommonWell password
CW_PASSWORD=your-password-here

# How long (in hours) to consider a saved session valid before re-authenticating
# Default: 24 hours
SESSION_MAX_AGE_HOURS=24

# How many days back to search for transactions (default: 7)
# Can be overridden via CLI: --days N
SEARCH_DAYS_BACK=7
